# ─────────────────────────────────────────────────────────────────────────────
# Environment template — copy to `.env` for local dev.
# Loaded automatically by spring-dotenv at startup. Values here override
# defaults in application.yml. Real `.env` is gitignored; this file is committed.
# ─────────────────────────────────────────────────────────────────────────────

# === Application ===========================================================
APP_NAME=springboot
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# === Database ==============================================================
# dev profile defaults to a local MySQL; prod profile REQUIRES these.
DB_URL=jdbc:mysql://localhost:3306/springboot_dev?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=
DB_DRIVER=com.mysql.cj.jdbc.Driver
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2
DB_POOL_CONNECTION_TIMEOUT_MS=30000

# === JPA / Hibernate =======================================================
# `validate` = entity ↔ schema mismatch fails startup. Pair with Flyway.
# Use `none` to disable, `update` only for throwaway sandboxes.
JPA_DDL_AUTO=validate
JPA_OPEN_IN_VIEW=false
JPA_TIME_ZONE=UTC
JPA_FORMAT_SQL=true
JPA_SHOW_SQL=true

# === Flyway ================================================================
FLYWAY_ENABLED=true
FLYWAY_BASELINE_ON_MIGRATE=true
FLYWAY_LOCATIONS=classpath:db/migration

# === CORS ==================================================================
# Comma-separated list of allowed origin patterns. Port wildcards are OK (http://localhost:*).
# In production, list your real frontend origins explicitly:
#   APP_SECURITY_CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
# NEVER use a bare "*" while ALLOW_CREDENTIALS=true.
APP_SECURITY_CORS_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*
APP_SECURITY_CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
APP_SECURITY_CORS_ALLOWED_HEADERS=*
APP_SECURITY_CORS_EXPOSED_HEADERS=Authorization,X-Request-Id,X-RateLimit-Limit,X-RateLimit-Remaining,Retry-After
APP_SECURITY_CORS_ALLOW_CREDENTIALS=true
APP_SECURITY_CORS_MAX_AGE=3600

# === JWT ===================================================================
# 256-bit (32-byte) base64 secret. Generate with:
#   openssl rand -base64 32
# NEVER ship the default value to production.
APP_SECURITY_JWT_SECRET=Y2hhbmdlLW1lLWluLXByb2QtdGhpcy1pcy1ub3Qtc2VjdXJlLXNlY3JldC1rZXk=
APP_SECURITY_JWT_ISSUER=springboot-template
APP_SECURITY_JWT_ACCESS_TTL_MINUTES=60
APP_SECURITY_JWT_REFRESH_TTL_DAYS=14

# === Sessions =============================================================
APP_SECURITY_SESSIONS_CLEANUP_INTERVAL=PT1H
APP_SECURITY_SESSIONS_CLEANUP_RETENTION=P7D

# === Email (SMTP) =========================================================
# Provider-agnostic. Pick a block below, fill in your credentials, leave the
# rest commented. Master switch is APP_MAIL_ENABLED — keep false in local dev
# until you want to test the forgot-password flow against a real inbox.
APP_MAIL_ENABLED=false
APP_MAIL_FROM=
APP_MAIL_FROM_NAME=Spring Boot Template
APP_MAIL_APP_URL=http://localhost:8080
APP_MAIL_PASSWORD_RESET_TTL=PT30M
APP_MAIL_PASSWORD_RESET_CLEANUP_INTERVAL=PT1H

# --- Gmail (personal account) ---------------------------------------------
# 1. Enable 2-Step Verification on your Google account.
# 2. Generate an App Password at https://myaccount.google.com/apppasswords
# 3. Use that 16-char password — NOT your real Google password.
# SPRING_MAIL_HOST=smtp.gmail.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=you@gmail.com
# SPRING_MAIL_PASSWORD=abcd-efgh-ijkl-mnop          # the App Password
# SPRING_MAIL_SMTP_AUTH=true
# SPRING_MAIL_SMTP_STARTTLS=true
# SPRING_MAIL_SMTP_SSL=false

# --- Outlook / Hotmail / Office 365 ---------------------------------------
# SPRING_MAIL_HOST=smtp.office365.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=you@outlook.com
# SPRING_MAIL_PASSWORD=your-password
# SPRING_MAIL_SMTP_AUTH=true
# SPRING_MAIL_SMTP_STARTTLS=true
# SPRING_MAIL_SMTP_STARTTLS_REQUIRED=true
# SPRING_MAIL_SMTP_SSL=false

# --- Yahoo Mail -----------------------------------------------------------
# Requires an App Password (Account Security → Generate App Password).
# SPRING_MAIL_HOST=smtp.mail.yahoo.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=you@yahoo.com
# SPRING_MAIL_PASSWORD=app-password
# SPRING_MAIL_SMTP_AUTH=true
# SPRING_MAIL_SMTP_STARTTLS=true

# --- SendGrid -------------------------------------------------------------
# username is literally the string "apikey", password is your API key.
# SPRING_MAIL_HOST=smtp.sendgrid.net
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=apikey
# SPRING_MAIL_PASSWORD=SG.xxxxxxxxxxxxxxxxxxxxxx
# SPRING_MAIL_SMTP_AUTH=true
# SPRING_MAIL_SMTP_STARTTLS=true

# --- Mailgun --------------------------------------------------------------
# SPRING_MAIL_HOST=smtp.mailgun.org
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=postmaster@<your-mailgun-domain>
# SPRING_MAIL_PASSWORD=<smtp-password-from-mailgun>
# SPRING_MAIL_SMTP_AUTH=true
# SPRING_MAIL_SMTP_STARTTLS=true

# --- Amazon SES -----------------------------------------------------------
# Create SMTP credentials in the SES console (different from AWS access keys).
# SPRING_MAIL_HOST=email-smtp.us-east-1.amazonaws.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=AKIA...
# SPRING_MAIL_PASSWORD=ses-smtp-password
# SPRING_MAIL_SMTP_AUTH=true
# SPRING_MAIL_SMTP_STARTTLS=true

# --- Self-hosted / Mailtrap / Postmark / Brevo / etc. ---------------------
# Any SMTP server works — just point host/port and the auth knobs at it.
# SPRING_MAIL_HOST=sandbox.smtp.mailtrap.io
# SPRING_MAIL_PORT=2525
# SPRING_MAIL_USERNAME=<mailtrap-username>
# SPRING_MAIL_PASSWORD=<mailtrap-password>
# SPRING_MAIL_SMTP_AUTH=true
# SPRING_MAIL_SMTP_STARTTLS=true

# === File storage ==========================================================
APP_STORAGE_BASE_PATH=uploads
MULTIPART_MAX_FILE_SIZE=10MB
MULTIPART_MAX_REQUEST_SIZE=12MB

# === Rate limiting =========================================================
# Bucket4j-backed per-identity (username when authenticated, IP otherwise).
# Master switch — false unregisters the filter entirely.
APP_RATE_LIMIT_ENABLED=true
# Default bucket: capacity = max burst, refill_tokens added every refill_period.
# refill_period uses ISO-8601 duration: PT1S, PT1M, PT1H.
APP_RATE_LIMIT_CAPACITY=60
APP_RATE_LIMIT_REFILL_TOKENS=60
APP_RATE_LIMIT_REFILL_PERIOD=PT1M
# Stricter bucket for /api/v1/auth/* — protects login from credential stuffing.
APP_RATE_LIMIT_AUTH_CAPACITY=10
APP_RATE_LIMIT_AUTH_REFILL_TOKENS=10
APP_RATE_LIMIT_AUTH_REFILL_PERIOD=PT1M

# === Audit logging =========================================================
# Master switch — false disables filter, aspect, executor, AND read API.
APP_AUDIT_ENABLED=true
# Independent — set false to keep capturing but hide GET /api/v1/audit-logs.
APP_AUDIT_EXPOSE_API=true
APP_AUDIT_AUDIT_ALL=true
APP_AUDIT_CAPTURE_REQUEST_BODY=true
APP_AUDIT_CAPTURE_RESPONSE_BODY=true
APP_AUDIT_MAX_BODY_LENGTH=10000

# === Idempotency ===========================================================
# Dedupes non-idempotent requests (POST/PATCH) annotated with @Idempotent.
# Clients send `Idempotency-Key: <uuid>` header; retries within ttl replay the cached response.
APP_IDEMPOTENCY_ENABLED=true
# ISO-8601 duration. PT24H = 24 hours.
APP_IDEMPOTENCY_TTL=PT24H
# How often the scheduled job purges expired records.
APP_IDEMPOTENCY_CLEANUP_INTERVAL=PT1H

# === Caching ===============================================================
# Backend selection — the ONLY cache knob exposed via env.
# Per-cache TTLs and sizes are tuned in application.yml (app.cache.*).
#   caffeine — in-memory (default, no extra infra)
#   redis    — see README "Switching cache to Redis" for the one-time setup
#   none     — disable caching globally (annotations become no-ops)
SPRING_CACHE_TYPE=caffeine

# === Redis (only when SPRING_CACHE_TYPE=redis; uncomment after adding the starter) ====
# SPRING_DATA_REDIS_HOST=localhost
# SPRING_DATA_REDIS_PORT=6379
# SPRING_DATA_REDIS_PASSWORD=
# SPRING_DATA_REDIS_DATABASE=0

# === OpenAPI / Swagger =====================================================
SPRINGDOC_SWAGGER_UI_PATH=/swagger-ui.html
SPRINGDOC_API_DOCS_PATH=/v3/api-docs

# === Logging ===============================================================
LOG_DIR=logs
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG

# === Actuator ==============================================================
# Comma-separated list of endpoints to expose under /actuator.
MANAGEMENT_ENDPOINTS=health,info,metrics
# Options: never, when-authorized, always
MANAGEMENT_HEALTH_DETAILS=when-authorized
